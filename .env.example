# Copy this file to ".env" in the same folder (custom_nodes/openrouter_node).
# The real ".env" is gitignored so your key is not committed.
#
# Get a key: https://openrouter.ai/

# Primary variable (recommended)
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Optional alias (only used if OPENROUTER_API_KEY is unset or empty)
# OPENROUTER_KEY=
